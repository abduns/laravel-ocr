{
    "name": "abduns/laravel-ocr",
    "description": "Laravel-first wrapper around Tesseract 5 OCR.",
    "license": "MIT",
    "keywords": ["laravel", "ocr", "tesseract", "pdf", "image"],
    "authors": [
        {
            "name": "Abdun Syakuur",
            "email": "abdun@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/bus": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/queue": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/console": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/filesystem": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "symfony/process": "^6.0 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.13"
    },
    "autoload": {
        "psr-4": {
            "Dunn\\LaravelOcr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dunn\\LaravelOcr\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dunn\\LaravelOcr\\OcrServiceProvider"
            ],
            "aliases": {
                "Ocr": "Dunn\\LaravelOcr\\Facades\\Ocr"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
